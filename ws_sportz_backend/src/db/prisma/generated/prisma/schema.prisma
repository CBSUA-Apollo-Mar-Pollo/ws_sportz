// Prisma schema for real-time sports application
// PostgreSQL database with Prisma ORM

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enum for match status
enum MatchStatus {
  SCHEDULED @map("scheduled")
  LIVE      @map("live")
  FINISHED  @map("finished")
}

model Match {
  id        String      @id @default(cuid()) @map("id")
  sport     String      @map("sport")
  homeTeam  String      @map("home_team")
  awayTeam  String      @map("away_team")
  status    MatchStatus @default(SCHEDULED) @map("status")
  startTime DateTime    @map("start_time")
  endTime   DateTime?   @map("end_time")
  homeScore Int         @default(0) @map("home_score")
  awayScore Int         @default(0) @map("away_score")
  createdAt DateTime    @default(now()) @map("created_at")

  // Relations
  commentaries Commentary[]

  @@map("matches")
}

model Commentary {
  id        String   @id @default(cuid()) @map("id")
  matchId   String   @map("match_id")
  minute    Int      @map("minute")
  sequence  Int      @map("sequence")
  period    Int      @map("period")
  eventType String   @map("event_type")
  actor     String   @map("actor")
  team      String   @map("team")
  message   String   @map("message")
  metadata  Json?    @map("metadata")
  tags      String[] @map("tags")
  createdAt DateTime @default(now()) @map("created_at")

  // Foreign key relation
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("commentaries")
}
